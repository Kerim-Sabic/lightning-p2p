{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "app": {
    "windows": [
      {
        "title": "Lightning P2P",
        "width": 1024,
        "height": 720,
        "minWidth": 1024,
        "minHeight": 600,
        "maximized": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "targets": ["app", "dmg"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
