{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Lightning P2P",
  "version": "0.2.2",
  "identifier": "com.lightningp2p.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lightning P2P",
        "width": 1024,
        "height": 720,
        "minWidth": 1024,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Lightning P2P",
    "homepage": "https://github.com/Kerim-Sabic/lightning-p2p",
    "shortDescription": "Direct peer-to-peer file transfers with iroh and Tauri.",
    "longDescription": "Lightning P2P is a Windows-first desktop app for direct peer-to-peer file transfer with verified iroh-blobs streaming, relay-aware WAN reachability, and polished native installers.",
    "createUpdaterArtifacts": false,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "headerImage": "icons/installer/nsis-header.bmp",
        "sidebarImage": "icons/installer/nsis-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "startMenuFolder": "Lightning P2P"
      },
      "wix": {
        "bannerPath": "icons/installer/wix-banner.bmp",
        "dialogImagePath": "icons/installer/wix-dialog.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Kerim-Sabic/lightning-p2p/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1NUREQzIzRUEwQzc3MUUKUldRZWR3enFJOXhkNVZtUkFFZUZicTgyVitIbXYraERRZUFPS0gvbTJmVGFWbHozRGJMdFhjZDEK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
