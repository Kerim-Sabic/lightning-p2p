# Optional local development overrides.
# Copy to .env only when you need a local profile or a predictable device name.

# Run two local desktop instances side-by-side:
# LIGHTNING_P2P_PROFILE=alice

# Name shown to nearby peers:
# LIGHTNING_P2P_DEVICE_NAME=Kerim Workstation

# Store app data outside the default OS app-data directory:
# LIGHTNING_P2P_DATA_DIR=C:\tmp\lightning-p2p-dev
